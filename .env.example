# =============================================================================
# Groover — P0.1 platform env mesh (0x0-platform-contract.md)
# =============================================================================
# Copy to .env for local dev, Hermes cron hosts, or Railway worker env.
# Field workers: deploy/README.md · Registry: packages/marketplace/
# =============================================================================

# -----------------------------------------------------------------------------
# Platform contract (cross-repo)
# -----------------------------------------------------------------------------

# Dynamo MCP base URL (Railway production).
DYNAMO_MCP_URL=https://mcp-production-80e2.up.railway.app

# Full call_connected_tool URL — engage-core governance calls.
# engage-config.ts resolves: DYNAMO_MCP env OR ${DYNAMO_MCP_URL}/call_connected_tool
# DYNAMO_MCP=https://mcp-production-80e2.up.railway.app/call_connected_tool

# xray-governance MCP (internal deliberation — P0.6b callDeliberationRound).
# Default localhost:4002; production Railway (requires GOVERNANCE_API_KEY):
# GOVERNANCE_MCP_URL=https://governance-production-69c3.up.railway.app
# GOVERNANCE_MCP_PATH=/mcp
# GOVERNANCE_API_KEY=

# Legacy Dynamo evaluate_governance HTTP (distinct from govern_with_solar hammer).
# GOVERNANCE_ENDPOINT=https://mcp-production-80e2.up.railway.app/governance

# 0xRay consumer project root (optional — MCP servers default to cwd).
# XRAY_ROOT=/path/to/groover

# Repertoire package root for consult + post-tick feedback.
# Default: sibling ../repertoire, then node_modules/@0xray/repertoire
# REPERTOIRE_ROOT=/path/to/repertoire

# Moltbook add-on only — not required for engage-core dry-run, triage, or Repertoire ingest.
# Each project activates its own key for deploy/moltbook-*.ts cron workers.
# MOLTBOOK_API_KEY=

# -----------------------------------------------------------------------------
# engage-config.ts overrides (optional)
# -----------------------------------------------------------------------------

# MOLTBOOK_API_BASE=https://www.moltbook.com/api/v1
# GROOVER_DID=did:groover:284895bead2ac15b
# DYNAMO_BLOCK_RESONANCE_THRESHOLD=0.75
# MAX_ACTIONS_PER_RUN=4

# -----------------------------------------------------------------------------
# Dry-run / triage toggles (optional)
# -----------------------------------------------------------------------------

# DRY_RUN=true
# SKIP_HERMES=1
# SKIP_GOVERNANCE=1
# SKIP_REPERTOIRE_FEEDBACK=1
# LIVE_READ=1